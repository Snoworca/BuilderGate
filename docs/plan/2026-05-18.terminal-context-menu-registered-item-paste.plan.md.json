  "requirements": [
    {"id": "FR-ARCH-001", "statement": "Context menu supports nested child menus through level 5, strips deeper children, and omits empty/actionless items."},
    {"id": "FR-ARCH-002", "statement": "Root and child context menus stay inside the screen through flip, clamp, and scroll behavior."},
    {"id": "FR-ARCH-003", "statement": "Mobile context menu always renders as a dialog with path header and back navigation."},
    {"id": "FR-ARCH-004", "statement": "Terminal registered item context menu pastes command, directory, or prompt values without executing them."},
    {"id": "FR-ARCH-005", "statement": "Registered item menus hide empty categories and reload a stable fresh snapshot on menu open."},
    {"id": "FR-ARCH-006", "statement": "Registered item load and paste failures remain observable and never silently execute or coerce unsafe input."}
  ],
