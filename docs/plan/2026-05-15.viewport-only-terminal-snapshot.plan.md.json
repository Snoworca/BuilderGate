  "requirements": [
    {"id": "FR-SESS-007", "statement": "Server creates viewport-only screen snapshots and uses replay handshake on subscribe, resubscribe, and reconnect."},
    {"id": "FR-SESS-008", "statement": "Snapshot payloads must not exceed configured max bytes."},
    {"id": "FR-SESS-015", "statement": "Browser terminal_snapshot_* fallback storage is viewport-only and cannot revive full scrollback."},
    {"id": "FR-SESS-016", "statement": "Snapshot restore and screen repair are distinct and cannot replay full normal buffer scrollback."},
    {"id": "FR-SESS-017", "statement": "Screen repair only includes viewport row patch, geometry, buffer type, cursor metadata, and repair token."},
    {"id": "FR-SESS-018", "statement": "Long scrollback AI TUI sessions must not re-inject full past scrollback during refresh, reconnect, or resubscribe."},
    {"id": "FR-WS-005", "statement": "Server queues output until screen-snapshot ACK."},
    {"id": "FR-WS-006", "statement": "Stale ACK does not break a newer replay flow."},
    {"id": "FR-WS-007", "statement": "Client reconnect restores subscriptions."},
    {"id": "AC-009", "statement": "Reconnect recovery uses viewport-only screen snapshot."},
    {"id": "AC-017", "statement": "Terminal snapshot storage budget and quota behavior remain valid."},
    {"id": "AC-020", "statement": "Grid repair and movement do not full replay scrollback."},
    {"id": "AC-023", "statement": "Refresh, reconnect, and resubscribe do not replay full scrollback and do not guarantee old scrollback lookup without lazy loading."}
  ],
