{
  "name": "buildergate-server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --include config.json5 src/index.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/shell-integration', 'dist/shell-integration', {recursive:true})\"",
    "start": "node dist/index.js",
    "test": "npm run build && node dist/test-runner.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "http-proxy": "^1.18.1",
    "json5": "^2.2.3",
    "jsonwebtoken": "^9.0.3",
    "node-pty": "^1.0.0",
    "nodemailer": "^7.0.12",
    "otplib": "^13.4.0",
    "qrcode-terminal": "^0.12.0",
    "selfsigned": "^5.4.0",
    "uuid": "^9.0.1",
    "ws": "^8.20.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/http-proxy": "^1.17.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.5",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/selfsigned": "^2.0.4",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
