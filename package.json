{
  "name": "buildergate",
  "private": true,
  "version": "0.2.0",
  "bin": {
    "buildergate": "tools/start-runtime.js"
  },
  "pkg": {
    "scripts": [
      "tools/start-runtime.js",
      "tools/daemon/cli.js",
      "tools/daemon/config-preflight.js",
      "tools/daemon/launcher.js",
      "tools/daemon/log.js",
      "tools/daemon/process-info.js",
      "tools/daemon/readiness.js",
      "tools/daemon/runtime-paths.js",
      "tools/daemon/sentinel-entry.js",
      "tools/daemon/sentinel.js",
      "tools/daemon/state-store.js",
      "tools/daemon/stop-client.js",
      "tools/daemon/totp-preflight.js",
      "server/dist-pkg/*.cjs",
      "server/node_modules/node-pty/lib/**/*.js"
    ],
    "assets": [
      "server/node_modules/node-pty/package.json",
      "server/node_modules/node-pty/prebuilds/**/*",
      "server/node_modules/node-pty/build/Release/*.node"
    ]
  },
  "scripts": {
    "build": "npm run build:daemon-all",
    "build:daemon-all": "node tools/build-daemon-exe.js --all-supported",
    "build:daemon-exe": "node tools/build-daemon-exe.js",
    "build:windows-amd64": "node tools/build-daemon-exe.js --profile win-amd64",
    "build:linux-amd64": "node tools/build-daemon-exe.js --profile linux-amd64",
    "build:windows-arm64": "node tools/build-daemon-exe.js --profile win-arm64",
    "build:linux-arm64": "node tools/build-daemon-exe.js --profile linux-arm64",
    "build:macos-arm64": "node tools/build-daemon-exe.js --profile macos-arm64",
    "build:daemon-win-arm64": "npm run build:windows-arm64",
    "build:daemon-linux-arm64": "npm run build:linux-arm64",
    "build:daemon-mac-arm64": "npm run build:macos-arm64",
    "build:daemon-macos-arm64": "npm run build:macos-arm64",
    "test:daemon": "npm --prefix server run build && node --test tools/daemon/*.test.js",
    "test:docs": "node --test tools/daemon/docs.test.js",
    "test:integration:native-daemon": "node --test tools/daemon/native-daemon.integration.test.js"
  }
}
